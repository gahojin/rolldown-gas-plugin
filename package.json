{
  "name": "@gahojin-inc/rolldown-gas-plugin",
  "version": "2026.6.0",
  "description": "Rolldown plugin for Google App Script",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/rolldown-gas-plugin.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "rolldown",
    "rolldown-plugin",
    "gas",
    "google-app-script"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "build": "rolldown -c",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check --write .",
    "check": "tsc --noEmit",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage",
    "test:update": "vitest --update",
    "bench": "vitest bench",
    "ncu": "mise run ncu"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@fast-check/vitest": "0.4.1",
    "@types/node": "25.9.3",
    "@vitest/coverage-v8": "4.1.8",
    "rolldown": "1.1.0",
    "rolldown-plugin-dts": "0.25.2",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "rolldown": "*"
  },
  "packageManager": "pnpm@11.5.1"
}
