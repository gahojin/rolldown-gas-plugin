{
  "name": "@gahojin-inc/rolldown-gas-plugin",
  "version": "0.7.1",
  "description": "Rolldown plugin for Google App Script",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/rolldown-gas-plugin.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "rolldown",
    "gas",
    "google-app-script"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "build": "rolldown -c",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check --write .",
    "check": "tsgo",
    "check:packagejson": "pnpm attw --profile esm-only --pack .",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage",
    "test:update": "vitest --update",
    "bench": "vitest bench",
    "ncu": "mise run ncu"
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.7",
    "@fast-check/vitest": "0.3.0",
    "@types/node": "24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260311.1",
    "@vitest/coverage-v8": "4.1.0",
    "jest-extended": "7.0.0",
    "rolldown": "1.0.0-rc.9",
    "unplugin-isolated-decl": "0.15.7",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  },
  "packageManager": "pnpm@10.32.1"
}
