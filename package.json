{
  "name": "@gahojin-inc/rolldown-gas-plugin",
  "version": "2026.4.1",
  "description": "Rolldown plugin for Google App Script",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/rolldown-gas-plugin.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "rolldown",
    "rolldown-plugin",
    "gas",
    "google-app-script"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "build": "rolldown -c",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check --write .",
    "check": "tsgo",
    "check:packagejson": "pnpm attw --pack . --profile esm-only --ignore-rules cjs-resolves-to-esm",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage",
    "test:update": "vitest --update",
    "bench": "vitest bench",
    "ncu": "mise run ncu"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.11",
    "@fast-check/vitest": "0.4.0",
    "@types/node": "24.12.2",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "@vitest/coverage-v8": "4.1.4",
    "jest-extended": "7.0.0",
    "rolldown": "1.0.0-rc.15",
    "rolldown-plugin-dts": "0.23.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "rolldown": "*"
  },
  "packageManager": "pnpm@10.33.0"
}
